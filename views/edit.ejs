<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Edit your book</title>
        <link rel="stylesheet" href="/styles/main.css" />
    </head>
    <body>
        <nav>
            <div class="logo">📚 Book Notes</div>

            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/add">Add Book</a>
                <a href="/reviews">My Reviews</a>
                <a href="/about">About</a>
            </div>
        </nav>

        <section class="form-header">
            <h1>Edit Book</h1>
            <p>Update your book details, review, and notes.</p>
        </section>

        <form action="/edit/<%= book.id %>" method="post" class="page-form">
            <label>Book Title</label>
            <input name="title" value="<%= book.title %>" />

            <label>Author</label>
            <input name="author" value="<%= book.author %>" />

            <label>ISBN</label>
            <input name="isbn" value="<%= book.isbn %>" />

            <label>Rating</label>
            <input
                name="rating"
                type="number"
                min="1"
                max="5"
                value="<%= book.rating %>"
            />

            <label>Review</label>
            <textarea name="review"><%= book.review %></textarea>

            <label>Notes</label>
            <textarea name="notes"><%= book.notes %></textarea>

            <label>Date Read</label>
            <input
                type="date"
                name="date_read"
                value="<%= book.date_read ? book.date_read.toISOString().split('T')[0] : '' %>"
            />

            <button type="submit">Update Book</button>
        </form>

        <footer>
            Made with Node.js, Express, EJS, PostgreSQL and Open Library Covers
            API.
        </footer>
    </body>
</html>
