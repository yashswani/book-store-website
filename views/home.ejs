<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Notes</title>
    <link rel="stylesheet" href="/styles/main.css">
</head>

<body>
    <nav>
        <div class="logo">📚 Book Notes</div>

        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/add">Add Book</a>
            <a href="/reviews">My Reviews</a>
            <a href="/about">About</a>
        </div>
    </nav>

    <section class="hero">
        <div class="hero-content">
            <h1>My Book Notes & Reviews</h1>
            <p>
                Save important ideas, reviews, ratings, and notes from the books you read.
                Build your personal library of insights.
            </p>
            <a href="/add" class="hero-btn">Add New Book</a>
        </div>
    </section>

    <section class="stats-section">
        <div class="stat-card">
            <h3>Total Books</h3>
            <p><%= stats.total_books || 0 %></p>
        </div>

        <div class="stat-card">
            <h3>Average Rating</h3>
            <p><%= stats.average_rating || "0" %>/5</p>
        </div>

        <div class="stat-card">
            <h3>Latest Book</h3>
            <p><%= latestBook ? latestBook.title : "No books yet" %></p>
        </div>
    </section>

    <form action="/" method="get" class="sort-form">
        <button type="submit" name="sort" value="rating">Sort by Rating</button>
        <button type="submit" name="sort" value="recent">Sort by Recent</button>
        <button type="submit" name="sort" value="title">Sort by Title</button>
    </form>

    <% if (bookData.length === 0) { %>
        <section class="empty-state">
            <h2>No books added yet</h2>
            <p>Start building your personal book notes library.</p>
            <a href="/add">Add Your First Book</a>
        </section>
    <% } else { %>
        <div class="books-grid">
            <% bookData.forEach((book) => { %>
                <div class="book-card">
                    <img class="book-cover" src="<%= book.cover_url %>" alt="<%= book.title %> cover">

                    <div class="book-info">
                        <h2><%= book.title %></h2>
                        <p class="book-author"><%= book.author %></p>

                        <p class="stars">
                            <%= "★".repeat(book.rating) %><%= "☆".repeat(5 - book.rating) %>
                        </p>

                        <p class="book-date">
                            📅 Date Read:
                            <%= book.date_read ? book.date_read.toLocaleDateString("en-IN", {
                                day: "numeric",
                                month: "long",
                                year: "numeric"
                            }) : "No date added" %>
                        </p>

                        <p class="book-review">
                            <%= book.review %>
                        </p>

                        <div class="book-actions">
                            <form class="card-action-form" action="/edit/<%= book.id %>" method="get">
                                <button class="edit-btn" type="submit">Edit</button>
                            </form>

                            <form class="card-action-form" action="/delete/<%= book.id %>" method="post">
                                <button
                                    class="delete-btn"
                                    type="submit"
                                    onclick="return confirm('Are you sure you want to delete this book?')"
                                >
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>

    <footer>
        Made with Node.js, Express, EJS, PostgreSQL and Open Library Covers API.
    </footer>
</body>
</html>